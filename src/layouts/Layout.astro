---
import { ViewTransitions } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import 'aos/dist/aos.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Portfolio de Gastón Ferraris Davies — Desarrollador Full Stack" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.png" />
		<meta name="robots" content="index, follow">
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		<title>{title}</title>
		<ViewTransitions />
	</head>
	<body class="bg-zinc-950 text-zinc-100 min-h-screen flex flex-col">
		<Navbar />
		<main class="flex-grow">
			<slot />
		</main>
		<script>
			import AOS from 'aos';
			document.addEventListener('DOMContentLoaded', function() {
				AOS.init({
					duration: 500,
					easing: 'ease-out',
					once: true,
					offset: 40,
				});
			});
		</script>
		<Footer />
	</body>
</html>

<style is:global>
	html {
		font-family: 'Inter', system-ui, sans-serif;
		background: #09090b;
	}

	body {
		color: #f4f4f5;
	}

	.card {
		@apply bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden transition-all duration-300 hover:border-zinc-700;
	}

	.badge {
		@apply text-xs font-medium px-2.5 py-1 rounded-md bg-violet-500/10 text-violet-400 border border-violet-500/20;
	}

	::selection {
		background: rgba(139, 92, 246, 0.25);
	}

	::-webkit-scrollbar {
		width: 4px;
	}

	::-webkit-scrollbar-track {
		background: #09090b;
	}

	::-webkit-scrollbar-thumb {
		background: #3f3f46;
		border-radius: 2px;
	}
</style>
