---
---

<style is:global>
  html, body {
    overflow-x: hidden;
    width: 100vw;
    max-width: 100vw;
  }
</style>

<section id="hero" class="min-h-screen flex items-center pt-24 pb-20 px-6">
  <div class="container mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-16">

      <!-- Text -->
      <div class="md:w-3/5" data-aos="fade-up">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-500/10 border border-emerald-500/20 rounded-full text-emerald-400 text-xs font-medium mb-8">
          <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
          Disponible para nuevas oportunidades
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tight mb-4 tracking-tight">
          Gastón<br />
          <span class="text-zinc-400 font-light">Ferraris Davies</span>
        </h1>

        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-px bg-violet-500"></div>
          <span class="text-sm text-violet-400 font-medium tracking-wide uppercase">Desarrollador Full Stack</span>
        </div>

        <p class="text-zinc-400 text-base leading-relaxed max-w-lg mb-10">
          Estudiante avanzado de Ingeniería en Sistemas de Información en la UTN.
          Especializado en el desarrollo web full-stack con React, Next.js y Supabase.
          Apasionado por construir soluciones funcionales y bien diseñadas.
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href="#contact"
            class="px-5 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors duration-200"
          >
            Contactar
          </a>
          <a
            href="#projects"
            class="px-5 py-2.5 border border-zinc-700 text-zinc-300 hover:border-zinc-500 hover:text-zinc-100 text-sm font-medium rounded-lg transition-colors duration-200"
          >
            Ver proyectos
          </a>
        </div>
      </div>

      <!-- Photo -->
      <div class="md:w-2/5 flex justify-center md:justify-end" data-aos="fade-up" data-aos-delay="120">
        <div class="relative">
          <div class="w-56 h-56 md:w-68 md:h-68 lg:w-72 lg:h-72 overflow-hidden rounded-2xl border border-zinc-800">
            <img
              src="/image.jpeg"
              alt="Gastón Ferraris Davies"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="absolute -bottom-3 -right-3 w-full h-full rounded-2xl border border-violet-500/25 -z-10"></div>
        </div>
      </div>

    </div>
  </div>
</section>
