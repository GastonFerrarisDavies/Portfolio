---
const projects = [
  {
    title: "Don Nicola E-commerce",
    description: "Sistema de gestión de producción para empresa agrolactea. Control de stock de materia prima, órdenes de producción, productos terminados y dashboard con estadísticas en tiempo real.",
    image: "/Donnicola.png",
    tags: ["React", "Node.js", "Supabase", "Tailwind CSS"],
    github: null,
    demo: "https://movax-flow-frontend.onrender.com",
    status: "live",
    featured: true
  },
  {
    title: "Oros",
    description: "Aplicación web para seguimiento de hábitos y bienestar personal. Permite a los usuarios crear rutinas diarias, establecer metas de salud, registrar actividades y visualizar su progreso a través de gráficos interactivos.",
    image: "/Oros.png",
    tags: ["React", "Next.js", "Supabase", "Tailwind CSS"],
    github: null,
    demo: "https://www.oros.center",
    status: "live",
    featured: false
  },
  {
    title: "Movax",
    description: "App web para la publicidad, venta y contacto con clientes de una empresa desarrolladora de software. Permite mostrar los servicios ofrecidos, proyectos destacados, testimonios de clientes y un formulario de contacto para consultas comerciales.",
    image: "/Movax.png",
    tags: ["React", "Next.js", "PostgreSQL", "Tailwind CSS"],
    github: null,
    demo: null,
    status: "live",
    featured: false
  },
  {
    title: "Portfolio",
    description: "Sitio web de portfolio personal construido con Astro para máximo rendimiento estático. Diseño minimalista, animaciones suaves y formulario de contacto integrado con EmailJS.",
    image: "/PortfolioWeb.png",
    tags: ["Astro", "Tailwind CSS", "TypeScript"],
    github: "https://github.com/GastonFerrarisDavies/Portfolio.git",
    demo: "https://gastonferrarisdavies.vercel.app/",
    status: "live",
    featured: false
  }
];
---

<section id="projects" class="py-24 px-6 border-t border-zinc-800/50">
  <div class="container mx-auto">

    <!-- Header -->
    <div class="mb-14" data-aos="fade-up">
      <span class="text-xs text-violet-400 uppercase tracking-[0.15em] font-medium">02 — Proyectos</span>
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-100 mt-2">Trabajos Recientes</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
      {projects.map((project, index) => (
        <div
          class={`card group flex flex-col ${project.featured ? 'lg:col-span-2' : ''}`}
          data-aos="fade-up"
          data-aos-delay={80 * (index + 1)}
        >
          <!-- Image -->
          <div class={`relative overflow-hidden flex-shrink-0 ${project.featured ? 'h-72' : 'h-52'}`}>
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/30 to-transparent"></div>

            <!-- Status badge -->
            <div class="absolute top-4 left-4">
              {project.status === 'live' && (
                <span class="inline-flex items-center gap-1.5 text-xs bg-zinc-950/80 backdrop-blur-sm text-emerald-400 border border-emerald-500/25 px-2.5 py-1 rounded-full">
                  <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></span>
                  En línea
                </span>
              )}
              {project.status === 'wip' && (
                <span class="inline-flex items-center gap-1.5 text-xs bg-zinc-950/80 backdrop-blur-sm text-amber-400 border border-amber-500/25 px-2.5 py-1 rounded-full">
                  <span class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse"></span>
                  En desarrollo
                </span>
              )}
            </div>
          </div>

          <!-- Content -->
          <div class="p-6 flex flex-col flex-1">
            <div class="flex flex-wrap gap-2 mb-3">
              {project.tags.map(tag => (
                <span class="badge">{tag}</span>
              ))}
            </div>

            <h3 class="text-lg font-bold text-zinc-100 mb-2">{project.title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed flex-1">{project.description}</p>

            <!-- Links -->
            <div class="flex items-center gap-4 mt-5 pt-5 border-t border-zinc-800">
              {project.github ? (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 text-sm text-zinc-400 hover:text-zinc-100 transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
                  </svg>
                  Código
                </a>
              ) : (
                <span class="flex items-center gap-2 text-sm text-zinc-600 cursor-default select-none">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
                  </svg>
                  Privado
                </span>
              )}

              {project.demo && (
                <a
                  href={project.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 text-sm text-violet-400 hover:text-violet-300 transition-colors ml-auto"
                >
                  Ver demo
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
