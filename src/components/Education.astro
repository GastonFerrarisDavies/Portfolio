---
const education = [
  {
    title: "Ingeniería en Sistemas de Información",
    institution: "Universidad Tecnológica Nacional — F.R.L.P.",
    period: "2022 — Presente",
    description: "Carrera de grado orientada al desarrollo, diseño, implementación y gestión de sistemas de información."
  }
];

const languages = [
  { name: "Inglés", level: "Avanzado — B2", note: "Cambridge English Certificate, 2021" },
  { name: "Español", level: "Nativo", note: "" }
];

const skills = [
  {
    category: "Frontend",
    items: ["React", "Next.js", "Astro", "TypeScript", "Tailwind CSS", "HTML & CSS"]
  },
  {
    category: "Backend",
    items: ["Node.js", "Supabase", "PostgreSQL", "API REST", "Django"]
  },
  {
    category: "Herramientas",
    items: ["Git", "GitHub", "Vercel", "Figma"]
  }
];
---

<section id="education" class="py-24 px-6 border-t border-zinc-800/50">
  <div class="container mx-auto">

    <!-- Header -->
    <div class="mb-14" data-aos="fade-up">
      <span class="text-xs text-violet-400 uppercase tracking-[0.15em] font-medium">01 — Sobre mí</span>
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-100 mt-2">Formación & Habilidades</h2>
    </div>

    <!-- Education + Languages -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">

      <!-- University -->
      {education.map((edu, i) => (
        <div class="card p-6" data-aos="fade-up" data-aos-delay={100 * (i + 1)}>
          <div class="flex items-center gap-2.5 mb-5">
            <div class="w-7 h-7 bg-violet-500/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
              </svg>
            </div>
            <span class="text-xs font-semibold text-zinc-400 uppercase tracking-widest">Universidad</span>
          </div>
          <p class="text-xs text-violet-400 font-medium mb-1.5">{edu.period}</p>
          <h3 class="text-base font-semibold text-zinc-100 mb-1">{edu.title}</h3>
          <p class="text-sm text-zinc-400 mb-3">{edu.institution}</p>
          <p class="text-sm text-zinc-500 leading-relaxed">{edu.description}</p>
        </div>
      ))}

      <!-- Languages -->
      <div class="card p-6" data-aos="fade-up" data-aos-delay="200">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="w-7 h-7 bg-violet-500/10 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
            </svg>
          </div>
          <span class="text-xs font-semibold text-zinc-400 uppercase tracking-widest">Idiomas</span>
        </div>
        <div class="space-y-5">
          {languages.map(lang => (
            <div class="border-l border-zinc-700 pl-4">
              <h3 class="text-base font-semibold text-zinc-100">{lang.name}</h3>
              <p class="text-sm text-zinc-400">{lang.level}</p>
              {lang.note && <p class="text-xs text-zinc-600 mt-0.5">{lang.note}</p>}
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Tech Skills -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {skills.map((group, i) => (
        <div class="card p-6" data-aos="fade-up" data-aos-delay={100 * (i + 1)}>
          <span class="text-xs font-semibold text-zinc-400 uppercase tracking-widest block mb-4">{group.category}</span>
          <div class="flex flex-wrap gap-2">
            {group.items.map(item => (
              <span class="badge">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
